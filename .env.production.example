# Production environment variables — set these in Vercel dashboard (Settings > Environment Variables)
# Never commit real values here

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

PORT=3000
NODE_ENV=production

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"

# Your Vercel deployment URL (no trailing slash)
WEB_ORIGIN="https://YOUR-APP.vercel.app"

GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Must match Authorized redirect URIs in Google Cloud Console
GOOGLE_CALLBACK_URL="https://YOUR-APP.vercel.app/api/v1/auth/google/callback"

# Do NOT set NODE_TLS_REJECT_UNAUTHORIZED in production
